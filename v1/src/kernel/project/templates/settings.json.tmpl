{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cbim_session_start.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/cbim_auto_preview.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cbim_session_end.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cbim_stop.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cbim_user_prompt_submit.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cbim_pre_tool_use.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cbim_post_tool_use.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Write(.cbim/**)",
      "Edit(.cbim/**)",
      "Read(.cbim/**)",
      "Bash(.cbim/run *)"
    ]
  },
  "mcpServers": {
    "cbim": {
      "command": ".cbim/run",
      "args": ["mcp"]
    }
  }
}
