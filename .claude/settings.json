{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .cbim/hooks/load_memory.py"
          },
          {
            "type": "command",
            "command": "python3 .cbim/hooks/auto_preview.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .cbim/hooks/write_memory.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .cbim/hooks/end_session.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .cbim/hooks/log_user_prompt.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .cbim/hooks/log_pre_tool.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .cbim/hooks/log_post_tool.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Write(.cbim/memory/**)",
      "Edit(.cbim/memory/**)",
      "Glob(.cbim/memory/**)",
      "Grep(.cbim/memory/**)"
    ]
  },
  "mcpServers": {
    "cbim": {
      "command": ".venv/bin/python3",
      "args": [
        ".cbim/mcp_server/server.py"
      ]
    }
  }
}
